# ── Grin Wallet CLI ────────────────────────────────────────────
# Primary binary: name (if in PATH) or full path.
# The server tries this first, then falls back to GRIN_WALLET_FALLBACK.
GRIN_WALLET_BIN=grin-wallet

# Fallback binary path used when GRIN_WALLET_BIN is not found (ENOENT).
# Default matches the Grin Node Toolkit install location.
GRIN_WALLET_FALLBACK=/opt/grin/cmdwallet/mainnet/grin-wallet

# ── Passphrase (choose ONE method) ────────────────────────────
#
# Option 1 — Interactive prompt (most secure, no disk storage)
#   Don't set anything below. The server prompts at startup.
#   Passphrase lives in memory only — never touches disk.
#   Best for: manually-started servers.
#
# Option 2 — OS keyring via secret-tool (secure + survives restarts)
#   Requires: libsecret / secret-tool  (apt install libsecret-tools)
#   Store once (run as the service user):
#     secret-tool store --label="Grin wallet" service grin-wallet account mainnet
#   Then enable here:
# GRIN_WALLET_PASS_KEYRING=1
#
# Option 3 — Environment variable (least secure, visible in /proc/<pid>/environ)
# GRIN_WALLET_PASS=your_passphrase_here

# ── Server ─────────────────────────────────────────────────────
PORT=3001

# Allowed frontend origins (comma-separated)
CORS_ORIGINS=http://localhost:8080,https://yourdomain.com

# ── SQLite / uploads ───────────────────────────────────────────
TOOLS_DB=/opt/office-tools/data/tools.db
UPLOADS_DIR=/opt/office-tools/data/uploads

# ── Grin Wallet Owner API ──────────────────────────────────────
# Your Grin wallet's Owner API endpoint (usually localhost unless tunneled)
GRIN_OWNER_URL=http://127.0.0.1:3420/v3/owner

# Grin wallet passphrase for opening the wallet via API
GRIN_WALLET_PASS=your_grin_wallet_password_here

# Grin Foreign API (for receiving transactions)
GRIN_FOREIGN_URL=http://127.0.0.1:3415/v2/foreign

# ── PocketBase ─────────────────────────────────────────────────
PB_URL=http://127.0.0.1:8090

# PocketBase admin credentials (payment server needs to create records)
PB_ADMIN_EMAIL=admin@yourdomain.com
PB_ADMIN_PASSWORD=your_pocketbase_admin_password

# ── Server ─────────────────────────────────────────────────────
PORT=3001

# Allowed frontend origins (comma-separated)
CORS_ORIGINS=http://localhost:8080,https://yourdomain.com

# Payment expiry window in minutes
PAYMENT_EXPIRY_MINUTES=30

# ── Plan amounts in nanogrin (1 GRIN = 1,000,000,000 nanogrin) ─
PLAN_PRO_MONTHLY_NANOGRIN=10000000000
PLAN_PRO_YEARLY_NANOGRIN=100000000000
PLAN_LIFETIME_NANOGRIN=500000000000

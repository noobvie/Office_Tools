# ── Wallet passphrase — needed for open_wallet call ──────────
# Same file written by deploy_grinwallet.sh (chmod 640, root:grin)
GRIN_WALLET_PASS_FILE=/opt/office-tools/data/.temp

# ── Grin Wallet APIs ──────────────────────────────────────────
# Foreign API (port 3415, grin-wallet listen) — used by donate/receive
GRIN_FOREIGN_API=http://127.0.0.1:3415/v2/foreign

# Owner API (port 3420, grin-wallet owner_api) — used by donate/invoice and donate/finalize
# Uses init_secure_api ECDH + AES-256-GCM encryption (handled automatically).
GRIN_OWNER_API=http://127.0.0.1:3420/v3/owner

# Foreign API secret — Basic Auth for port 3415
# File auto-created by grin-wallet at wallet_data/.api_secret
GRIN_API_SECRET_FILE=/opt/office-tools/cmdgrinwallet/wallet_data/.api_secret

# Owner API secret — Basic Auth for port 3420
# File auto-created by grin-wallet at .owner_api_secret
GRIN_OWNER_API_SECRET_FILE=/opt/office-tools/cmdgrinwallet/.owner_api_secret

# Port probe target for /api/wallet/status badge (checks donate_grin_tor)
GRIN_LISTEN_PORT=3415
GRIN_LISTEN_HOST=127.0.0.1

# ── Feedback email notifications ───────────────────────────────
# Uses the OS sendmail command (postfix/exim must be configured on the server).
# Leave blank to disable email — messages are still saved to SQLite.
# Set this during deploy.sh setup, or edit this file directly on the server.
NOTIFY_EMAIL=
NOTIFY_EMAIL_2=

# ── Temp Inbox (throwaway email tool) ──────────────────────────
# Domain that throwaway addresses are minted under (e.g. inbox.grin.money).
# Leave blank to disable the Temp Inbox tool (the other email tools work without it).
# To actually RECEIVE mail you must also: (1) add an MX record for this domain
# pointing at this server, and (2) configure your MTA (postfix/exim) to pipe inbound
# messages to POST /api/email/inbox/ingest with the X-Ingest-Secret header below.
TEMP_INBOX_DOMAIN=
# Shared secret the MTA must send as the X-Ingest-Secret header on /api/email/inbox/ingest.
INBOX_INGEST_SECRET=
# Minutes an inbox lives before it (and its mail) is auto-pruned. Default 60.
TEMP_INBOX_TTL_MIN=60

# ── Server ─────────────────────────────────────────────────────
PORT=3001

# Allowed frontend origins (comma-separated)
CORS_ORIGINS=http://localhost:8080,https://yourdomain.com

# ── SQLite / uploads ───────────────────────────────────────────
TOOLS_DB=/opt/office-tools/data/tools.db
UPLOADS_DIR=/opt/office-tools/data/uploads
